# TownPulse environment variables.
# Copy to .env and fill in real values. .env is gitignored.
# In dev, every value below has a safe default in settings.py and you can
# leave most of these unset. In prod (DEBUG=False), SECRET_KEY, ALLOWED_HOSTS,
# CORS_ALLOWED_ORIGINS, CSRF_TRUSTED_ORIGINS, and DB_PASSWORD must be set.

# --- Django core ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
# "True" or "False". Default True in dev.
DEBUG=True
# Comma-separated. In prod include the EC2 public IP and any domain.
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated full origins (scheme + host [+ :port]).
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# --- Database ---
DB_NAME=townpulse_db
DB_USER=postgres
DB_PASSWORD=postgres
# In docker-compose this is the service name "db". Locally without docker, 127.0.0.1.
DB_HOST=db
DB_PORT=5432

# --- Third-party APIs ---
# https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=
# Google Cloud Console OAuth 2.0 Client ID (used by /api/auth/google/).
GOOGLE_CLIENT_ID=
# Optional: data.seattle.gov app token for higher rate limits.
SEATTLE_SOCRATA_APP_TOKEN=
# Override only if pointing at a different Socrata dataset.
# SEATTLE_SOCRATA_DOMAIN=data.seattle.gov
# SEATTLE_SOCRATA_DATASET_ID=6853-bgsc
# SEATTLE_SOCRATA_DATE_FIELD=date
